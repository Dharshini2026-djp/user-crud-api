# ─────────────────────────────────────────────
#  Environment Variables – copy to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# MongoDB connection string
# Local:  mongodb://localhost:27017/user_crud_api
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/user_crud_api
MONGODB_URI=mongodb://localhost:27017/user_crud_api

# bcrypt – number of salt rounds (10–12 recommended for production)
BCRYPT_SALT_ROUNDS=10
